{
  "@context": "https://www.w3.org/ns/solid/oidc-context.jsonld",
  "client_id": "https://github.com/CybrKat/SpireApp/client-profile.jsonld",
  "client_name": "SpireApp",
  "application_type": "native",
  "redirect_uris": [
    "https://github.com/CybrKat/SpireApp/redirect.html",
    "com.example.spireapp://redirect",
    "http://localhost:4400/redirect.html"
  ],
  "post_logout_redirect_uris": [
    "https://github.com/CybrKat/SpireApp/redirect.html",
    "com.example.spireapp://redirect",
    "http://localhost:4400/redirect.html"
  ],
  "scope": "openid profile offline_access webid",
  "grant_types": [
    "authorization_code",
    "refresh_token"
  ],
  "response_types": [
    "code"
  ],
  "token_endpoint_auth_method": "none"
}
